        {"step_id": "s4", "text": "Toss the pasta with the sauce and sliced chicken.", "actions": [{"verb": "toss", "targets": ["pasta", "basil pesto", "heavy cream", "chicken breast"]}]},
        {"step_id": "s5", "text": "Finish with parmesan and serve warm.", "actions": [{"verb": "garnish", "targets": ["parmesan"]}]}
