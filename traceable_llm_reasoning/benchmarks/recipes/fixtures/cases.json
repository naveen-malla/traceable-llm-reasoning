      "title": "Creamy Chicken Pesto Pasta",
      "category": "pasta",
      "summary": "A rich pasta dish with chicken, basil pesto, cream, and parmesan.",
      "ingredients": [
        {"name": "chicken breast", "quantity": 2, "unit": "pieces", "roles": ["protein"]},
        {"name": "pasta", "quantity": 300, "unit": "g", "roles": ["base"], "tags": ["gluten"]},
        {"name": "basil pesto", "quantity": 4, "unit": "tbsp", "roles": ["sauce"], "tags": ["nuts", "dairy"]},
        {"name": "heavy cream", "quantity": 120, "unit": "ml", "roles": ["sauce"], "tags": ["dairy"]},
        {"name": "parmesan", "quantity": 40, "unit": "g", "roles": ["topping"], "tags": ["dairy"]},
        {"name": "olive oil", "quantity": 1, "unit": "tbsp", "roles": ["fat"]},
        {"name": "garlic", "quantity": 2, "unit": "cloves", "roles": ["aromatic"]},
        {"name": "salt", "quantity": 1, "unit": "tsp", "roles": ["seasoning"]}
      ],
      "steps": [
        {"step_id": "s1", "text": "Season the chicken and sear it in olive oil until cooked through.", "actions": [{"verb": "sear", "targets": ["chicken breast"]}]},
        {"step_id": "s2", "text": "Cook the pasta in salted water until al dente.", "actions": [{"verb": "boil", "targets": ["pasta"]}]},
